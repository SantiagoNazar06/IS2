<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Gestión de Asignaciones</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-100 min-h-screen p-6">
    <div class="max-w-6xl mx-auto">
        <div class="bg-white p-8 rounded-lg shadow-lg mb-8">
            <h1 class="text-3xl font-bold text-gray-800 mb-2">Gestión de Asignaciones</h1>
            <p class="text-gray-600 mb-6">Asigná docentes a materias para cada período y rol.</p>

            {{#errorMessage}}
            <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded mb-4">{{errorMessage}}</div>
            {{/errorMessage}}
            {{#successMessage}}
            <div class="bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded mb-4">{{successMessage}}</div>
            {{/successMessage}}

            <form action="/admin/assignments" method="POST" class="grid grid-cols-1 md:grid-cols-4 gap-4 mb-8">
                <div>
                    <label for="teacherId" class="block text-sm font-medium text-gray-700 mb-1">Docente</label>
                    <select name="teacherId" id="teacherId" required
                            class="w-full border border-gray-300 rounded-md py-2 px-3 focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
                        <option value="">Seleccionar docente</option>
                        {{#teachers}}
                        <option value="{{teacherId}}">{{firstName}} {{lastName}} ({{legajo}})</option>
                        {{/teachers}}
                    </select>
                </div>

                <div>
                    <label for="subjectId" class="block text-sm font-medium text-gray-700 mb-1">Materia</label>
                    <select name="subjectId" id="subjectId" required
                            class="w-full border border-gray-300 rounded-md py-2 px-3 focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
                        <option value="">Seleccionar materia</option>
                        {{#subjects}}
                        <option value="{{id}}">{{code}} - {{name}}</option>
                        {{/subjects}}
                    </select>
                </div>

                <div>
                    <label for="period" class="block text-sm font-medium text-gray-700 mb-1">Período</label>
                    <input type="text" name="period" id="period" placeholder="Ej: 2025-1" required
                           pattern="\d{4}-[12]"
                           title="Formato: YYYY-S (ej: 2025-1)"
                           class="w-full border border-gray-300 rounded-md py-2 px-3 focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
                </div>

                <div>
                    <label for="role" class="block text-sm font-medium text-gray-700 mb-1">Rol</label>
                    <select name="role" id="role" required
                            class="w-full border border-gray-300 rounded-md py-2 px-3 focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
                        <option value="">Seleccionar rol</option>
                        <option value="RESPONSABLE">RESPONSABLE</option>
                        <option value="JTP">JTP</option>
                        <option value="AYUDANTE">AYUDANTE</option>
                    </select>
                </div>

                <div class="md:col-span-4">
                    <button type="submit"
                            class="w-full bg-blue-600 text-white py-2 px-4 rounded-md hover:bg-blue-700 transition duration-300 font-medium">
                        Asignar
                    </button>
                </div>
            </form>

            <h2 class="text-2xl font-bold text-gray-800 mb-4">Asignaciones Existentes</h2>

            {{#hasAssignments}}
            <div class="overflow-x-auto border border-gray-200 rounded-lg">
                <table class="w-full text-left">
                    <thead class="bg-gray-50 border-b border-gray-200">
                        <tr>
                            <th class="py-3 px-4 text-sm font-semibold text-gray-600">Docente</th>
                            <th class="py-3 px-4 text-sm font-semibold text-gray-600">Materia</th>
                            <th class="py-3 px-4 text-sm font-semibold text-gray-600">Período</th>
                            <th class="py-3 px-4 text-sm font-semibold text-gray-600">Rol</th>
                            <th class="py-3 px-4 text-sm font-semibold text-gray-600">Acción</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-gray-100">
                        {{#assignments}}
                        <tr class="hover:bg-gray-50">
                            <td class="py-3 px-4 text-gray-800">{{firstName}} {{lastName}}</td>
                            <td class="py-3 px-4 text-gray-800">{{subject_name}}</td>
                            <td class="py-3 px-4 text-gray-600">{{period}}</td>
                            <td class="py-3 px-4">
                                <span class="inline-block px-2 py-1 text-xs font-semibold rounded-full
                                    {{#isResponsable}}bg-blue-100 text-blue-800{{/isResponsable}}
                                    {{#isJtp}}bg-green-100 text-green-800{{/isJtp}}
                                    {{#isAyudante}}bg-yellow-100 text-yellow-800{{/isAyudante}}">
                                    {{role}}
                                </span>
                            </td>
                            <td class="py-3 px-4">
                                <form action="/admin/assignments/{{id}}/delete" method="POST"
                                      onsubmit="return confirm('¿Eliminar esta asignación?')">
                                    <button type="submit"
                                            class="bg-red-500 text-white py-1 px-3 rounded-md hover:bg-red-600 transition duration-300 text-sm">
                                        Eliminar
                                    </button>
                                </form>
                            </td>
                        </tr>
                        {{/assignments}}
                    </tbody>
                </table>
            </div>
            {{/hasAssignments}}
            {{^hasAssignments}}
            <p class="text-gray-500 text-center py-8">No hay asignaciones registradas.</p>
            {{/hasAssignments}}
        </div>
    </div>
</body>
</html>
