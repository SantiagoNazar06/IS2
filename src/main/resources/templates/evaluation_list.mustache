<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Listado de Calificaciones</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-100 p-6 min-h-screen">
    <div class="max-w-4xl mx-auto bg-white p-8 rounded-lg shadow-lg">
        
        <div class="flex justify-between items-center mb-6">
            <h1 class="text-3xl font-bold text-gray-800">Calificaciones Registradas</h1>
            <a href="/grades/new" class="bg-blue-600 text-white py-2 px-4 rounded-md hover:bg-blue-700 transition">
                + Nueva Calificación
            </a>
        </div>

        {{#message}}
        <div class="bg-blue-100 border border-blue-400 text-blue-700 px-4 py-3 rounded relative mb-4" role="alert">
            <span class="block sm:inline">{{message}}</span>
        </div>
        {{/message}}

        <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="bg-gray-200 text-gray-700 uppercase text-sm">
                        <th class="py-3 px-6">ID Evaluación</th>
                        <th class="py-3 px-6">ID Inscripción</th>
                        <th class="py-3 px-6">Calificación</th>
                        <th class="py-3 px-6">Fecha de Carga</th>
                    </tr>
                </thead>
                <tbody class="text-gray-600 text-sm">
                    {{#evaluations}}
                    <tr class="border-b hover:bg-gray-50">
                        <td class="py-3 px-6">{{getEvaluationId}}</td>
                        <td class="py-3 px-6 font-medium text-gray-900">{{getEvaluationEnrollementId}}</td>
                        <td class="py-3 px-6 font-bold text-blue-600">{{getEvaluationGrade}}</td>
                        <td class="py-3 px-6">{{getEvaluationDate}}</td>
                    </tr>
                    {{/evaluations}}
                    {{^evaluations}}
                    <tr>
                        <td colspan="4" class="py-6 text-center text-gray-400">No hay calificaciones registradas en el sistema.</td>
                    </tr>
                    {{/evaluations}}
                </tbody>
            </table>
        </div>
        
        <div class="mt-6 text-center">
            <a href="/dashboard" class="text-blue-600 hover:underline">Volver al Dashboard</a>
        </div>
    </div>
</body>
</html>