<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{#isEdit}}Editar{{/isEdit}}{{^isEdit}}Nuevo{{/isEdit}} Plan de Estudio</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-100 min-h-screen p-4">
    <div class="bg-white p-8 rounded-lg shadow-lg w-full max-w-lg mx-auto">
        <h1 class="text-3xl font-bold text-center text-gray-800 mb-6">
            {{#isEdit}}Editar Plan de Estudio{{/isEdit}}
            {{^isEdit}}Nuevo Plan de Estudio{{/isEdit}}
        </h1>

        {{#error}}
        <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded relative mb-4" role="alert">
            <span class="block sm:inline">{{error}}</span>
        </div>
        {{/error}}

        <form method="POST" action="{{#isEdit}}/study-plans/manage/{{plan.id}}/update{{/isEdit}}{{^isEdit}}/study-plans/manage/create{{/isEdit}}"
              class="space-y-4">

            <!-- Nombre -->
            <div>
                <label for="name" class="block text-sm font-medium text-gray-700 mb-1">Nombre del Plan</label>
                <input type="text" id="name" name="name" required
                       value="{{#plan}}{{name}}{{/plan}}"
                       class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500"
                       placeholder="Ej: Plan 2024">
            </div>

            <!-- Año -->
            <div>
                <label for="year" class="block text-sm font-medium text-gray-700 mb-1">Año</label>
                <input type="number" id="year" name="year" required min="2000" max="2099"
                       value="{{#plan}}{{year}}{{/plan}}{{^plan}}2024{{/plan}}"
                       class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500">
            </div>

            <!-- Carrera -->
            <div>
                <label for="careerId" class="block text-sm font-medium text-gray-700 mb-1">Carrera</label>
                <select id="careerId" name="careerId" required
                        class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500">
                    <option value="">Seleccione una carrera</option>
                    {{#careers}}
                    <option value="{{id}}" {{#isSelected}}selected{{/isSelected}}>{{careerName}}</option>
                    {{/careers}}
                </select>
            </div>

            <!-- Botones -->
            <div class="flex items-center justify-between pt-4">
                <a href="/study-plans/manage"
                   class="text-gray-600 hover:underline text-sm">Cancelar</a>
                <button type="submit"
                        class="px-6 py-2 bg-indigo-600 text-white text-sm font-medium rounded-lg hover:bg-indigo-700 transition-colors">
                    {{#isEdit}}Guardar Cambios{{/isEdit}}
                    {{^isEdit}}Crear Plan{{/isEdit}}
                </button>
            </div>
        </form>
    </div>
</body>
</html>