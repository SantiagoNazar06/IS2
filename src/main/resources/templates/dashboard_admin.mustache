<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard Admin</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-100 flex items-center justify-center min-h-screen p-4">
    <div class="bg-white p-8 rounded-lg shadow-lg w-full max-w-4xl">
        <h1 class="text-3xl font-bold text-center text-gray-800 mb-6">Panel de Administración</h1>

        {{#username}}
        <p class="text-xl text-center text-gray-700 mb-8">¡Bienvenido, <span class="font-semibold text-blue-600">{{username}}</span>!</p>
        {{/username}}

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
            <div class="bg-yellow-50 border border-yellow-200 p-6 rounded-lg text-center shadow-sm">
                <h2 class="text-2xl font-bold text-yellow-700 mb-3">Registrar Profesor</h2>
                <p class="text-gray-600 mb-4">Ingresá la información de un nuevo profesor.</p>
                <a href="/register_teacher" class="inline-block bg-yellow-600 text-white py-2 px-4 rounded-md hover:bg-yellow-700 transition duration-300">Registrar</a>
            </div>

            <div class="bg-pink-50 border border-pink-200 p-6 rounded-lg text-center shadow-sm">
                <h2 class="text-2xl font-bold text-pink-700 mb-3">Registrar Estudiante</h2>
                <p class="text-gray-600 mb-4">Ingresá la información de un nuevo estudiante.</p>
                <a href="/register_student" class="inline-block bg-pink-600 text-white py-2 px-4 rounded-md hover:bg-pink-700 transition duration-300">Registrar</a>
            </div>

            <div class="bg-indigo-50 border border-indigo-200 p-6 rounded-lg text-center shadow-sm">
                <h2 class="text-2xl font-bold text-indigo-700 mb-3">Gestionar Carreras</h2>
                <p class="text-gray-600 mb-4">Administrá las ofertas académicas.</p>
                <a href="/register_career" class="inline-block bg-indigo-600 text-white py-2 px-4 rounded-md hover:bg-indigo-700 transition duration-300">Gestionar</a>
            </div>

            <div class="bg-teal-50 border border-teal-200 p-6 rounded-lg text-center shadow-sm">
                <h2 class="text-2xl font-bold text-teal-700 mb-3">Gestionar Materias</h2>
                <p class="text-gray-600 mb-4">Administrá las materias y planes de estudio.</p>
                <a href="/subjects" class="inline-block bg-teal-600 text-white py-2 px-4 rounded-md hover:bg-teal-700 transition duration-300">Gestionar</a>
            </div>

            <div class="bg-purple-50 border border-purple-200 p-6 rounded-lg text-center shadow-sm">
                <h2 class="text-2xl font-bold text-purple-700 mb-3">Listado de Estudiantes</h2>
                <p class="text-gray-600 mb-4">Visualizá todos los estudiantes registrados.</p>
                <a href="/students" class="inline-block bg-purple-600 text-white py-2 px-4 rounded-md hover:bg-purple-700 transition duration-300">Ver Listado</a>
            </div>

            <div class="bg-orange-50 border border-orange-200 p-6 rounded-lg text-center shadow-sm">
                <h2 class="text-2xl font-bold text-orange-700 mb-3">Listado de Profesores</h2>
                <p class="text-gray-600 mb-4">Visualizá todos los profesores registrados.</p>
                <a href="/teachers" class="inline-block bg-orange-600 text-white py-2 px-4 rounded-md hover:bg-orange-700 transition duration-300">Ver Listado</a>
            </div>

            <div class="bg-red-50 border border-red-200 p-6 rounded-lg text-center shadow-sm">
                <h2 class="text-2xl font-bold text-red-700 mb-3">Gestionar Calificaciones</h2>
                <p class="text-gray-600 mb-4">Administrá las actas de notas y evaluaciones.</p>
                <a href="/grades" class="inline-block bg-red-600 text-white py-2 px-4 rounded-md hover:bg-red-700 transition duration-300">Gestionar</a>
            </div>
        </div>

        <div class="text-center mt-6">
            <a href="/logout" class="inline-block bg-red-600 text-white py-2 px-6 rounded-md hover:bg-red-700 transition duration-300 text-lg">Cerrar Sesión</a>
        </div>
    </div>
</body>
</html>
