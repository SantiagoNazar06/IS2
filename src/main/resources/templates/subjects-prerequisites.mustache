<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Correlativas de {{subject.subjectName}}</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-100 min-h-screen p-4">
    <div class="bg-white p-8 rounded-lg shadow-lg w-full max-w-6xl mx-auto">
        <h1 class="text-3xl font-bold text-center text-gray-800 mb-6">Correlativas de {{subject.subjectName}}</h1>

        {{#message}}
        <div class="bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded relative mb-4" role="alert">
            <span class="block sm:inline">{{message}}</span>
        </div>
        {{/message}}

        {{#error}}
        <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded relative mb-4" role="alert">
            <span class="block sm:inline">{{error}}</span>
        </div>
        {{/error}}

        <!-- Tabla de correlativas -->
        <div class="overflow-x-auto mb-8">
            <table class="min-w-full bg-white border border-gray-200 rounded-lg">
                <thead class="bg-gray-50">
                    <tr>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Materia</th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Código</th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Tipo</th>
                        <th class="px-6 py-3 text-center text-xs font-medium text-gray-500 uppercase tracking-wider">Acciones</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-200">
                    {{#prerequisites}}
                    <tr class="hover:bg-gray-50">
                        <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">{{prerequisiteSubjectName}}</td>
                        <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-700">{{prerequisiteSubjectCode}}</td>
                        <td class="px-6 py-4 whitespace-nowrap text-sm">
                            <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full {{#isRegular}}bg-blue-100 text-blue-800{{/isRegular}}{{^isRegular}}bg-purple-100 text-purple-800{{/isRegular}}">
                                {{type}}
                            </span>
                        </td>
                        <td class="px-6 py-4 whitespace-nowrap text-sm text-center">
                            <form method="POST" action="/subjects/{{subjectId}}/prerequisites/{{id}}/delete"
                                  class="inline" onsubmit="return confirm('¿Estás seguro de eliminar esta correlativa?');">
                                <button type="submit"
                                        class="text-red-600 hover:text-red-800 font-medium">Eliminar</button>
                            </form>
                        </td>
                    </tr>
                    {{/prerequisites}}
                    {{^prerequisites}}
                    <tr>
                        <td colspan="4" class="px-6 py-8 text-center text-gray-500">
                            No tiene correlativas registradas.
                        </td>
                    </tr>
                    {{/prerequisites}}
                </tbody>
            </table>
        </div>

        <!-- Formulario para agregar correlativa -->
        <div class="border-t border-gray-200 pt-6">
            <h2 class="text-xl font-semibold text-gray-800 mb-4">Agregar Correlativa</h2>
            <form method="POST" action="/subjects/{{subjectId}}/prerequisites" class="space-y-4">
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                    <!-- Materia requisito -->
                    <div>
                        <label for="prerequisiteSubjectId" class="block text-sm font-medium text-gray-700 mb-1">Materia requisito</label>
                        <select id="prerequisiteSubjectId" name="prerequisiteSubjectId" required
                                class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
                            <option value="">Seleccionar materia...</option>
                            {{#availableSubjects}}
                            <option value="{{subjectId}}">{{subjectName}} ({{code}})</option>
                            {{/availableSubjects}}
                        </select>
                    </div>

                    <!-- Tipo de condicion -->
                    <div>
                        <label for="type" class="block text-sm font-medium text-gray-700 mb-1">Tipo de condición</label>
                        <select id="type" name="type" required
                                class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
                            {{#conditionTypes}}
                            <option value="{{name}}">{{label}}</option>
                            {{/conditionTypes}}
                        </select>
                    </div>
                </div>

                <div class="flex justify-end">
                    <button type="submit"
                            class="px-6 py-2 bg-blue-600 text-white text-sm font-medium rounded-lg hover:bg-blue-700 transition-colors">
                        Agregar Correlativa
                    </button>
                </div>
            </form>
        </div>

        <div class="text-center mt-6">
            <a href="/subjects/manage" class="text-gray-600 hover:underline">← Volver a Materias</a>
        </div>
    </div>
</body>
</html>
