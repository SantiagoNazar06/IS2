<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Actas de Calificaciones</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-100 p-6 min-h-screen">
    <div class="max-w-5xl mx-auto">
        {{#teacher}}
        <div class="mb-6">
            <h1 class="text-3xl font-bold text-gray-800">Actas de Calificaciones</h1>
            <p class="text-gray-500 mt-1">{{firstName}} {{lastName}} — Legajo {{legajo}}</p>
        </div>
        {{/teacher}}

        {{#subjectsWithGrades}}
        <div class="bg-white p-6 rounded-lg shadow-lg mb-6">
            <h2 class="text-xl font-bold text-gray-800 mb-1">{{subjectName}}</h2>
            <p class="text-sm text-gray-500 mb-4">{{role}} — Período {{period}}</p>

            <div class="overflow-x-auto">
                <table class="w-full text-left border-collapse">
                    <thead>
                        <tr class="bg-gray-100 text-gray-700 uppercase text-xs">
                            <th class="py-2 px-4">Alumno</th>
                            <th class="py-2 px-4">DNI</th>
                            <th class="py-2 px-4 text-center">Nota</th>
                            <th class="py-2 px-4 text-center">Fecha</th>
                        </tr>
                    </thead>
                    <tbody class="text-gray-600 text-sm">
                        {{#students}}
                        <tr class="border-b hover:bg-gray-50">
                            <td class="py-2 px-4 font-medium text-gray-900">{{lastName}}, {{firstName}}</td>
                            <td class="py-2 px-4">{{dni}}</td>
                            <td class="py-2 px-4 text-center">
                                {{#grade}}{{grade}}{{/grade}}
                                {{^grade}}<span class="text-gray-400 italic">Sin nota</span>{{/grade}}
                            </td>
                            <td class="py-2 px-4 text-center">
                                {{#gradeDate}}{{gradeDate}}{{/gradeDate}}
                                {{^gradeDate}}—{{/gradeDate}}
                            </td>
                        </tr>
                        {{/students}}
                        {{^students}}
                        <tr>
                            <td colspan="4" class="py-4 text-center text-gray-400">Sin alumnos evaluados.</td>
                        </tr>
                        {{/students}}
                    </tbody>
                </table>
            </div>
        </div>
        {{/subjectsWithGrades}}

        {{^subjectsWithGrades}}
        <div class="bg-white p-8 rounded-lg shadow-lg text-center text-gray-400">
            No tiene materias asignadas.
        </div>
        {{/subjectsWithGrades}}

        <div class="mt-4 text-center">
            <a href="/teachers/{{teacherId}}" class="text-blue-600 hover:underline">Volver al perfil</a>
        </div>
    </div>
</body>
</html>
