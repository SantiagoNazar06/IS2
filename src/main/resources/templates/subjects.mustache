    <!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Gestionar Materias</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-100 min-h-screen p-4">
    <div class="bg-white p-8 rounded-lg shadow-lg w-full max-w-6xl mx-auto">
        <h1 class="text-3xl font-bold text-center text-gray-800 mb-6">Gestión de Materias</h1>

        {{#message}}
        <div class="bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded relative mb-4" role="alert">
            <span class="block sm:inline">{{message}}</span>
        </div>
        {{/message}}

        {{#error}}
        <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded relative mb-4" role="alert">
            <span class="block sm:inline">{{error}}</span>
        </div>
        {{/error}}

        <!-- Filtro por carrera + boton Nueva Materia -->
        <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 mb-6">
            <form method="GET" action="/subjects/manage" class="flex items-center gap-3">
                <label for="careerId" class="text-sm font-medium text-gray-700 whitespace-nowrap">Filtrar por carrera:</label>
                <select name="careerId" id="careerId"
                        onchange="this.form.submit()"
                        class="border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
                    <option value="">Todas las carreras</option>
                    {{#careers}}
                    <option value="{{id}}" {{#isSelected}}selected{{/isSelected}}>{{careerName}}</option>
                    {{/careers}}
                </select>
            </form>

            <a href="/subjects/manage/new"
               class="inline-flex items-center px-4 py-2 bg-blue-600 text-white text-sm font-medium rounded-lg hover:bg-blue-700 transition-colors">
                + Nueva Materia
            </a>
        </div>

        <!-- Tabla de materias -->
        <div class="overflow-x-auto">
            <table class="min-w-full bg-white border border-gray-200 rounded-lg">
                <thead class="bg-gray-50">
                    <tr>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Código</th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Nombre</th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Plan de Estudio</th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Carrera</th>
                        <th class="px-6 py-3 text-center text-xs font-medium text-gray-500 uppercase tracking-wider">Correlativas</th>
                        <th class="px-6 py-3 text-center text-xs font-medium text-gray-500 uppercase tracking-wider">Notas</th>
                        <th class="px-6 py-3 text-center text-xs font-medium text-gray-500 uppercase tracking-wider">Acciones</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-200">
                    {{#subjects}}
                    <tr class="hover:bg-gray-50">
                        <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900">{{code}}</td>
                        <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-700">{{subjectName}}</td>
                        <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">{{studyPlanName}}</td>
                        <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">{{careerName}}</td>
                        <td class="px-6 py-4 whitespace-nowrap text-sm text-center">
                            <a href="/subjects/{{subjectId}}/prerequisites"
                               class="text-blue-600 hover:text-blue-800 font-medium">Ver</a>
                        </td>
                        <td class="px-6 py-4 whitespace-nowrap text-sm text-center">
                            <a href="/grades?subjectId={{subjectId}}"
                               class="text-green-600 hover:text-green-800 font-medium">Ver Notas</a>
                        </td>
                        <td class="px-6 py-4 whitespace-nowrap text-sm text-center space-x-2">
                            <a href="/subjects/manage/{{subjectId}}/edit"
                               class="text-yellow-600 hover:text-yellow-800 font-medium">Editar</a>
                            <form method="POST" action="/subjects/manage/{{subjectId}}/delete"
                                  class="inline" onsubmit="return confirm('¿Estás seguro de eliminar esta materia?');">
                                <button type="submit"
                                        class="text-red-600 hover:text-red-800 font-medium">Eliminar</button>
                            </form>
                        </td>
                    </tr>
                    {{/subjects}}
                    {{^subjects}}
                    <tr>
                        <td colspan="7" class="px-6 py-8 text-center text-gray-500">
                            No hay materias registradas.
                        </td>
                    </tr>
                    {{/subjects}}
                </tbody>
            </table>
        </div>

        <div class="text-center mt-6">
            <a href="/dashboard" class="text-gray-600 hover:underline">Volver al inicio</a>
        </div>
    </div>
</body>
</html>
