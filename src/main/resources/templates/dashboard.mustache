<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard - Bienvenido</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-100 flex items-center justify-center min-h-screen p-4">
    <div class="bg-white p-8 rounded-lg shadow-lg w-full max-w-4xl">
        <h1 class="text-3xl font-bold text-center text-gray-800 mb-6">Panel de Control</h1>

        {{#username}}
        <p class="text-xl text-center text-gray-700 mb-8">¡Bienvenido, <span class="font-semibold text-blue-600">{{username}}</span>!</p>
        {{/username}}

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">

            <!-- ============================================ -->
            <!-- SECCIONES COMUNES (todos los roles)           -->
            <!-- ============================================ -->

            <!-- Tu Perfil -->
            <div class="bg-blue-50 border border-blue-200 p-6 rounded-lg text-center shadow-sm">
                <h2 class="text-2xl font-bold text-blue-700 mb-3">Tu Perfil</h2>
                <p class="text-gray-600 mb-4">Gestiona la información de tu cuenta.</p>
                <a href="/profile" class="inline-block bg-blue-600 text-white py-2 px-4 rounded-md hover:bg-blue-700 transition duration-300">Ver Perfil</a>
            </div>

            <!-- ============================================ -->
            <!-- SECCIONES SOLO ADMIN                          -->
            <!-- ============================================ -->
            {{#isAdmin}}
            <div class="bg-indigo-50 border border-indigo-200 p-6 rounded-lg text-center shadow-sm">
                <h2 class="text-2xl font-bold text-indigo-700 mb-3">Gestionar Profesores</h2>
                <p class="text-gray-600 mb-4">Administra los profesores y sus datos.</p>
                <a href="/register_teacher" class="inline-block bg-indigo-600 text-white py-2 px-4 rounded-md hover:bg-indigo-700 transition duration-300">Gestionar</a>
            </div>

            <div class="bg-indigo-50 border border-indigo-200 p-6 rounded-lg text-center shadow-sm">
                <h2 class="text-2xl font-bold text-indigo-700 mb-3">Gestionar Estudiantes</h2>
                <p class="text-gray-600 mb-4">Administra los estudiantes y sus datos.</p>
                <a href="/register_student" class="inline-block bg-indigo-600 text-white py-2 px-4 rounded-md hover:bg-indigo-700 transition duration-300">Gestionar</a>
            </div>

            <div class="bg-indigo-50 border border-indigo-200 p-6 rounded-lg text-center shadow-sm">
                <h2 class="text-2xl font-bold text-indigo-700 mb-3">Gestionar Carreras</h2>
                <p class="text-gray-600 mb-4">Administra las ofertas académicas y duración de las carreras.</p>
                <a href="/register_career" class="inline-block bg-indigo-600 text-white py-2 px-4 rounded-md hover:bg-indigo-700 transition duration-300">Gestionar</a>
            </div>

            <div class="bg-teal-50 border border-teal-200 p-6 rounded-lg text-center shadow-sm">
                <h2 class="text-2xl font-bold text-teal-700 mb-3">Gestionar Materias</h2>
                <p class="text-gray-600 mb-4">Administra las materias y planes de estudio.</p>
                <a href="/subjects" class="inline-block bg-teal-600 text-white py-2 px-4 rounded-md hover:bg-teal-700 transition duration-300">Gestionar</a>
            </div>

            <div class="bg-red-50 border border-red-200 p-6 rounded-lg text-center shadow-sm md:col-span-2">
                <h2 class="text-2xl font-bold text-red-700 mb-3">Gestionar Calificaciones</h2>
                <p class="text-gray-600 mb-4">Administra las actas de notas finales y evaluaciones académicas.</p>
                <a href="/grades" class="inline-block bg-red-600 text-white py-2 px-4 rounded-md hover:bg-red-700 transition duration-300">Gestionar</a>
            </div>
            {{/isAdmin}}

            <!-- ============================================ -->
            <!-- SECCIONES SOLO TEACHER                        -->
            <!-- ============================================ -->
            {{#isTeacher}}
            <div class="bg-green-50 border border-green-200 p-6 rounded-lg text-center shadow-sm">
                <h2 class="text-2xl font-bold text-green-700 mb-3">Listado de Estudiantes</h2>
                <p class="text-gray-600 mb-4">Visualiza los estudiantes y sus datos.</p>
                <a href="/students" class="inline-block bg-green-600 text-white py-2 px-4 rounded-md hover:bg-green-700 transition duration-300">Ver Listado</a>
            </div>

            <div class="bg-indigo-50 border border-indigo-200 p-6 rounded-lg text-center shadow-sm">
                <h2 class="text-2xl font-bold text-indigo-700 mb-3">Gestionar Calificaciones</h2>
                <p class="text-gray-600 mb-4">Subí y modificá las notas de los estudiantes.</p>
                <a href="/grades" class="inline-block bg-indigo-600 text-white py-2 px-4 rounded-md hover:bg-indigo-700 transition duration-300">Gestionar</a>
            </div>
            {{/isTeacher}}

            <!-- ============================================ -->
            <!-- SECCIONES SOLO STUDENT                        -->
            <!-- ============================================ -->
            {{#isStudent}}
            <div class="bg-green-50 border border-green-200 p-6 rounded-lg text-center shadow-sm">
                <h2 class="text-2xl font-bold text-green-700 mb-3">Estado de Carrera</h2>
                <p class="text-gray-600 mb-4">Consultá tu progreso y estado académico.</p>
                <a href="/career-status" class="inline-block bg-green-600 text-white py-2 px-4 rounded-md hover:bg-green-700 transition duration-300">Ver Estado</a>
            </div>

            <div class="bg-indigo-50 border border-indigo-200 p-6 rounded-lg text-center shadow-sm">
                <h2 class="text-2xl font-bold text-indigo-700 mb-3">Mis Notas</h2>
                <p class="text-gray-600 mb-4">Consultá tus calificaciones y evaluaciones.</p>
                <a href="/grades" class="inline-block bg-indigo-600 text-white py-2 px-4 rounded-md hover:bg-indigo-700 transition duration-300">Ver Notas</a>
            </div>
            {{/isStudent}}

        </div>

        <div class="text-center mt-6">
            <a href="/logout" class="inline-block bg-red-600 text-white py-2 px-4 rounded-md hover:bg-red-700 transition duration-300 text-lg">Cerrar Sesión</a>
        </div>
    </div>
</body>
</html>
