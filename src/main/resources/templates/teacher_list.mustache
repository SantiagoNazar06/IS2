<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Listado de Docentes</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-100 p-6 min-h-screen">
    <div class="max-w-4xl mx-auto bg-white p-8 rounded-lg shadow-lg">
        <div class="flex justify-between items-center mb-6">
            <h1 class="text-3xl font-bold text-gray-800">Docentes</h1>
            <a href="/register_teacher" class="bg-yellow-600 text-white py-2 px-4 rounded-md hover:bg-yellow-700 transition">
                + Registrar Docente
            </a>
        </div>

        <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="bg-gray-200 text-gray-700 uppercase text-sm">
                        <th class="py-3 px-6">Legajo</th>
                        <th class="py-3 px-6">Apellido y Nombre</th>
                        <th class="py-3 px-6">DNI</th>
                        <th class="py-3 px-6">Email</th>
                        <th class="py-3 px-6 text-center">Acciones</th>
                    </tr>
                </thead>
                <tbody class="text-gray-600 text-sm">
                    {{#teachers}}
                    <tr class="border-b hover:bg-gray-50">
                        <td class="py-3 px-6">{{legajo}}</td>
                        <td class="py-3 px-6 font-medium text-gray-900">{{lastName}}, {{firstName}}</td>
                        <td class="py-3 px-6">{{dni}}</td>
                        <td class="py-3 px-6">{{email}}</td>
                        <td class="py-3 px-6 text-center">
                            <a href="/teachers/{{teacherId}}" class="text-blue-600 hover:text-blue-800 font-semibold">Ver detalle</a>
                        </td>
                    </tr>
                    {{/teachers}}
                    {{^teachers}}
                    <tr>
                        <td colspan="5" class="py-6 text-center text-gray-400">No hay docentes registrados.</td>
                    </tr>
                    {{/teachers}}
                </tbody>
            </table>
        </div>

        <div class="mt-6 text-center">
            <a href="/dashboard" class="text-blue-600 hover:underline">Volver al Dashboard</a>
        </div>
    </div>
</body>
</html>
