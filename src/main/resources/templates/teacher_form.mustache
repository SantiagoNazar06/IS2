<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>{{#editMode}}Editar Profesor{{/editMode}}{{^editMode}}Registrar Profesor{{/editMode}}</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-100 flex items-center justify-center min-h-screen p-4">
    <div class="bg-white p-8 rounded-lg shadow-lg w-full max-w-md">
        <h1 class="text-3xl font-bold text-center text-gray-800 mb-6">{{#editMode}}Editar Profesor{{/editMode}}{{^editMode}}Registrar Profesor{{/editMode}}</h1>

        {{#successMessage}}
        <div class="bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded relative mb-4" role="alert">
            <span class="block sm:inline">{{successMessage}}</span>
        </div>
        {{/successMessage}}

        {{#errorMessage}}
        <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded relative mb-4" role="alert">
            <span class="block sm:inline">{{errorMessage}}</span>
        </div>
        {{/errorMessage}}

        {{#editMode}}
        <form action="/update_teacher/{{teacherId}}" method="post" class="space-y-4">
        {{/editMode}}
        {{^editMode}}
        <form action="/register_teacher" method="post" class="space-y-4">
        {{/editMode}}
            <div>
                <label for="dni" class="block text-gray-700 text-sm font-medium mb-1">Dni Profesor:</label>
                <input type="text" id="dni" name="dni" value="{{#editMode}}{{dni}}{{/editMode}}" required
                       class="w-full px-4 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-indigo-500">
            </div>
            <div>
                <label for="nroLegajo" class="block text-gray-700 text-sm font-medium mb-1">Nro. Legajo:</label>
                <input type="text" id="nroLegajo" name="nroLegajo" value="{{#editMode}}{{nroLegajo}}{{/editMode}}" required
                       class="w-full px-4 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-indigo-500">
            </div>
            <div>
                <label for="firstName" class="block text-gray-700 text-sm font-medium mb-1">Nombre completo:</label>
                <input type="text" id="firstName" name="firstName" value="{{#editMode}}{{firstName}}{{/editMode}}" required
                       class="w-full px-4 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-indigo-500">
            </div>
            <div>
                <label for="lastName" class="block text-gray-700 text-sm font-medium mb-1">Apellido/s:</label>
                <input type="text" id="lastName" name="lastName" value="{{#editMode}}{{lastName}}{{/editMode}}" required
                       class="w-full px-4 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-indigo-500">
            </div>
            <div>
                <label for="phone" class="block text-gray-700 text-sm font-medium mb-1">Teléfono:</label>
                <input type="text" id="phone" name="phone" value="{{#editMode}}{{phone}}{{/editMode}}" required
                       class="w-full px-4 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-indigo-500">
            </div>
            <div>
                <label for="email" class="block text-gray-700 text-sm font-medium mb-1">Email:</label>
                <input type="text" id="email" name="email" value="{{#editMode}}{{email}}{{/editMode}}" required
                       class="w-full px-4 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-indigo-500">
            </div>
            <button type="submit"
                    class="w-full bg-indigo-600 text-white py-2 px-4 rounded-md hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2">
                {{#editMode}}Actualizar Profesor{{/editMode}}{{^editMode}}Registrar Profesor{{/editMode}}
            </button>

            <div class="flex justify-between items-center mt-4 text-sm">
                <a href="/dashboard" class="text-gray-600 hover:underline">Volver al inicio</a>
                <a href="/teachers" class="text-indigo-600 font-semibold hover:underline">Ver todos los profesores</a>
            </div>
        </form>
    </div>
</body>
</html>
