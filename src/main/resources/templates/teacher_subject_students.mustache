<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Alumnos de la Materia</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-100 p-6 min-h-screen">
    <div class="max-w-4xl mx-auto bg-white p-8 rounded-lg shadow-lg">
        <h1 class="text-3xl font-bold text-gray-800 mb-6">Alumnos de la Materia</h1>

        <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="bg-gray-200 text-gray-700 uppercase text-sm">
                        <th class="py-3 px-6">Apellido y Nombre</th>
                        <th class="py-3 px-6">DNI</th>
                        <th class="py-3 px-6">Email</th>
                        <th class="py-3 px-6">Tipo</th>
                        <th class="py-3 px-6 text-center">Nota</th>
                        <th class="py-3 px-6 text-center">Fecha</th>
                    </tr>
                </thead>
                <tbody class="text-gray-600 text-sm">
                    {{#students}}
                    <tr class="border-b hover:bg-gray-50">
                        <td class="py-3 px-6 font-medium text-gray-900">{{lastName}}, {{firstName}}</td>
                        <td class="py-3 px-6">{{dni}}</td>
                        <td class="py-3 px-6">{{email}}</td>
                        <td class="py-3 px-6">{{studentType}}</td>
                        <td class="py-3 px-6 text-center">
                            {{#grade}}{{grade}}{{/grade}}
                            {{^grade}}<span class="text-gray-400 italic">Sin nota</span>{{/grade}}
                        </td>
                        <td class="py-3 px-6 text-center">
                            {{#gradeDate}}{{gradeDate}}{{/gradeDate}}
                            {{^gradeDate}}—{{/gradeDate}}
                        </td>
                    </tr>
                    {{/students}}
                    {{^students}}
                    <tr>
                        <td colspan="6" class="py-6 text-center text-gray-400">No hay alumnos evaluados en esta materia.</td>
                    </tr>
                    {{/students}}
                </tbody>
            </table>
        </div>

        <div class="mt-6 text-center">
            <a href="/teachers/{{teacherId}}" class="text-blue-600 hover:underline">Volver al perfil del docente</a>
        </div>
    </div>
</body>
</html>
