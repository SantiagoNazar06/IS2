<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Registrar Calificación</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-100 flex items-center justify-center min-h-screen p-4">
    <div class="bg-white p-8 rounded-lg shadow-lg w-full max-w-md">
        <h1 class="text-3xl font-bold text-center text-gray-800 mb-6">Registrar Calificación</h1>

        {{#successMessage}}
        <div class="bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded relative mb-4" role="alert">
            <span class="block sm:inline">{{successMessage}}</span>
        </div>
        {{/successMessage}}

        {{#errorMessage}}
        <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded relative mb-4" role="alert">
            <span class="block sm:inline">{{errorMessage}}</span>
        </div>
        {{/errorMessage}}

        <form action="/grades" method="post" class="space-y-4">
            <div>
                <label for="enrollment_id" class="block text-gray-700 text-sm font-medium mb-1">ID de Inscripción:</label>
                <input type="number" id="enrollment_id" name="enrollment_id" required
                       class="w-full px-4 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500">
                <p class="text-xs text-gray-400 mt-1">ID único que vincula al alumno con la materia.</p>
            </div>
            <div>
                <label for="grade" class="block text-gray-700 text-sm font-medium mb-1">Nota Final:</label>
                <input type="number" id="grade" name="grade" min="0" max="10" step="0.01" required
                       class="w-full px-4 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500">
                <p class="text-xs text-gray-400 mt-1">Debe ser un valor numérico entre 0 y 10.</p>
            </div>
            
            <button type="submit"
                    class="w-full bg-blue-600 text-white py-2 px-4 rounded-md hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 transition">
                Guardar Nota
            </button>
            
            <div class="flex justify-between items-center mt-4 text-sm">
                <a href="/dashboard" class="text-gray-600 hover:underline">Volver al inicio</a>
                <a href="/grades" class="text-blue-600 font-semibold hover:underline">Ver calificaciones</a>
            </div>
        </form>
    </div>
</body>
</html>